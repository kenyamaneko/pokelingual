FROM node:22-alpine

WORKDIR /app

# build context をリポジトリルートに置く前提。shared/api-types を frontend と同じ相対位置で配置する。
COPY frontend/package.json frontend/package-lock.json ./frontend/
WORKDIR /app/frontend
RUN npm install

WORKDIR /app
COPY frontend ./frontend
COPY shared ./shared

WORKDIR /app/frontend

EXPOSE 15151

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
